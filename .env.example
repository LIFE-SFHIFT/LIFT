JWT_SECRET=replace-with-at-least-32-byte-secret
AUTH_ACCESS_TOKEN_TTL=1h
AUTH_REFRESH_TOKEN_TTL=14d

# 영구 PostgreSQL 연결. Neon/Supabase/Render Postgres의 JDBC URL을 넣는다.
# 예: jdbc:postgresql://host.neon.tech/dbname?sslmode=require
SPRING_DATASOURCE_URL=
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=
SPRING_JPA_HIBERNATE_DDL_AUTO=update

LIFT_BASE_URL=https://api.example.com
LIFT_FRONTEND_BASE_URL=https://app.example.com
LIFT_CORS_ALLOWED_ORIGINS=https://app.example.com
OAUTH_MOCK_ENABLED=false

KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=https://app.example.com/login/callback/kakao
KAKAO_SCOPE=

NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_REDIRECT_URI=https://app.example.com/login/callback/naver

# 공공데이터포털 > 행정안전부_대한민국 공공서비스(혜택) 정보 활용신청 후 발급받은 키
GOV24_PUBLIC_SERVICE_ENABLED=false
GOV24_PUBLIC_SERVICE_KEY=
GOV24_PUBLIC_SERVICE_PER_PAGE=1000
GOV24_PUBLIC_SERVICE_MAX_PAGES=2

TOSS_PAYMENTS_ENABLED=false
TOSS_SECRET_KEY=

OPENAI_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
